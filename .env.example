# MongoDB (Docker compose)
MONGODB_URI=mongodb://sb_app:sb_app_password@localhost:27017/spec_builder?authSource=spec_builder

# Auth.js / NextAuth
AUTH_SECRET=change_me_to_a_long_random_string
AUTH_URL=http://localhost:3000

# Backward compatibility (some setups still use this name)
NEXTAUTH_URL=http://localhost:3000

# Optional: if you use GitHub/Google providers later
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
